rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedInEmail() {
      return request.auth != null
        && request.auth.token.email != null;
    }

    function primaryInstructor() {
      return signedInEmail()
        && request.auth.token.email == "malinaceramik@gmail.com";
    }

    function bootstrapInstructor() {
      return signedInEmail()
        && request.auth.token.email in [
          "malinaceramik@gmail.com",
          "justyna.rusinek.studio@gmail.com",
          "paulina.a.bafia@gmail.com",
          "nataliatomecka04@gmail.com",
          "aleksandramyszkowiak@gmail.com",
          "kivachuk.polina@gmail.com"
        ];
    }

    function configuredInstructor() {
      return signedInEmail()
        && exists(/databases/$(database)/documents/access/instructors)
        && request.auth.token.email
          in get(/databases/$(database)/documents/access/instructors).data.emails;
    }

    function instructor() {
      return bootstrapInstructor() || configuredInstructor();
    }

    match /access/instructors {
      allow read: if bootstrapInstructor()
        || (signedInEmail() && request.auth.token.email in resource.data.emails);
      allow create, update, delete: if primaryInstructor();
    }

    match /studios/{studioId} {
      allow read, write: if instructor();

      match /notifications/{notificationId} {
        allow read, create: if instructor();
        allow update, delete: if false;
      }
    }

    match /pushTokens/{tokenId} {
      allow create, update: if instructor()
        && request.auth.uid == request.resource.data.uid;
      allow read, delete: if instructor()
        && request.auth.uid == resource.data.uid;
    }
  }
}
